# Pin the Node version pnpm uses for every command, regardless of the shell PATH.
# This is the durable fix for better-sqlite3 NODE_MODULE_VERSION (ABI) mismatches:
# pnpm auto-fetches/uses this Node so a stray system/Homebrew Node can't leak in.
# Keep in sync with .nvmrc / .node-version.
use-node-version=22.22.3

# Refuse to install under a Node that violates package.json "engines".
engine-strict=true
