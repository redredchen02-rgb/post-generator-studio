# Optional. Base directory for app data (db + encrypted secrets).
# Defaults to ~/.post-generator
POST_GENERATOR_HOME=~/.post-generator

# Optional. Explicit SQLite database path.
# Defaults to <POST_GENERATOR_HOME>/post-generator.db
POST_GENERATOR_DB_PATH=

# Required for local secret encryption outside development.
# Generate with: openssl rand -hex 32
POST_GENERATOR_SECRET_KEY=

# Optional. Provider request timeout in milliseconds. Defaults to 120000 (120s).
POST_GENERATOR_PROVIDER_TIMEOUT_MS=

# Optional app URL used by external callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:3000
